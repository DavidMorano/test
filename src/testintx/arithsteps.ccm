#ifdef	COMMENT
template<typename Dig>
constexpr int addc(Dig *r,const Dig v0,const Dig v1,int ci = 0) noex {
	Dig		co{} ;
	Dig		dci = cast_static<Dig>(ci) ;
	*r = mach_addc(v0,v1,dci,&co) ;
	return int(co) ;
} /* end subroutine (addc) */
#endif /* COMMENT */

template<typename Dig> constexpr void vclear(int n,Dig *v) noex {
	for (int i = 0 ; i < n ; i += 1) {
	    v[i] = 0 ;
	}
} /* end subroutine (vclear) */

template<typename Dig> constexpr void vcopy(int n,Dig *r,const Dig *v) noex {
	for (int i = 0 ; i < n ; i += 1) {
	    r[i] = v[i] ;
	}
} /* end subroutine (vcopy) */

/* how many digits are in a divisor-array, on the low end */
export {
    template<typename TA> constexpr int nsigdig(int n,TA *d) noex {
    	int c = 0 ;
    	for (int i = (n - 1) ; i >= 0 ; --i) {
	    if (d[i]) {
		c = (i + 1) ;
		break ;
	    }
	} /* end for */
    	return c ;
    } /* end subroutine-template (nsigdig) */
} /* end export */

#ifdef	COMMENT
constexpr void vmuler(int n,ulong *r,const ulong *v0,const ulong *v1) noex {
	cint nb = (szof(ulong) * CHAR_BIT) ;
	cint nh = (n / 2) ;
	ulonglong vl0 ;
	ulonglong vl1 ;
	ulonglong res ;
	vclear(n,r) ;
	for (int i = 0 ; i < nh ; i += 1) {
	    vl0 = v0[i] ;
	    for (int j = 0 ; j < nh ; j += 1) {
		ulong	tmp ;
		cint	ri = (i + j) ;
		int	co = 0 ;
	        vl1 = v1[j] ;
	        res = vl0 * vl1 ;
		tmp = ulongconv(res >> 0) ;
    		co = addc((r + ri + 0),r[ri + 0],tmp,co) ;
		tmp = ulongconv(res >> nb) ;
    		co = addc((r + ri + 1),r[ri + 1],tmp,co) ;
	    } /* end for */
	} /* end for */
} /* end subroutine (vmuler) */
#endif /* COMMENT */

template<typename TV,typename TA>
local TV vjoin(const TA *q) noex {
    cint	n = szof(TV) / szof(TA) ;
    cint	nb = nbits<TA> ;
    TV		res = 0 ;
    for (int i = (n - 1) ; i >= 0 ; --i) {
	TV v = q[i] ;
	res <<= nb ;
	res |= v ;
    } /* end for */
    return res ;
} /* end subroutine (vjoin) */

template<integral_unsigned T2,integral_unsigned T1>
    constexpr inline T1 divdigx(T1 *q,const T1 *dd,const T1 d) noex {
	T1		res = 0 ;
	if (d) {
	    cint nb = nbits<T1> ;
	    const T2 dd0 = dd[0] ;
	    const T2 dd1 = dd[1] ;
	    {
	        const T2 dividend =  (dd1 << nb) | dd0 ;
	        {
	            const T2 quo = dividend / d ;
	            const T2 rem = dividend % d ;
	            q[0] = T1(quo >> 00) ;
	            q[1] = T1(quo >> nb) ;
	            res = T1(rem) ;
	        } /* end block */
	    } /* end block */
	} /* end if (non-zero divisor) */
	return res ;
    } /* end subroutine (divdigx) */

export {
    constexpr int1 divdig(int1 *q,const int1 *dd,const int1 d) noex {
	return divdigx<uint>(q,dd,d) ;
    } /* end subroutine (divdig) */
    constexpr int2 divdig(int2 *q,const int2 *dd,const int2 d) noex {
	return divdigx<uint>(q,dd,d) ;
    } /* end subroutine (divdig) */
    constexpr int4 divdig(int4 *q,const int4 *dd,const int4 d) noex {
	return divdigx<ulong>(q,dd,d) ;
    } /* end subroutine (divdig) */
    constexpr int8 divdig(int8 *q,const int8 *dd,const int8 d) noex {
	return divdigx<ulonglong>(q,dd,d) ;
    } /* end subroutine (divdig) */
} /* end export */

/* n= number-of-dividend-and-quotient digits */
export {
    template<integral_unsigned T1>
    constexpr T1 vdivshort(int n,T1 *q,const T1 *dd,const T1 d) noex {
	T1 rem = 0 ;
	if (d) {
	    T1 ww[n+1] ;
	    T1 quo[2] ;
	    vcopy(n,ww,dd) ;
	    ww[n] = 0 ;
	    for (int i = (n - 1) ; i >= 0 ; --i) {
	        rem = divdig(quo,(ww + i),d) ;
	        q[i] = quo[0] ;
	        ww[i] = rem ;
	    } /* end for */
	} /* end if (non-zero divisor) */
	return rem ;
    } /* end subroutine (vdivshort) */
} /* end export */

export {
    template<typename T,typename TA> 
    constexpr void mkv(T *rp,const TA *a) noex {
	cint nb = nbits<TA> ;
    	cint sz_ta = szof(TA) ;
    	cint n = szof(T) / sz_ta ;
    	T res{} ;
	for (int i = 0 ; i < n ; i += 1) {
	    T tmp = T(a[i]) ;
	    tmp <<= (i * nb) ;
	    res |= tmp ;
	} /* end for */
        *rp = res ;
    } /* end if (mkv) */
} /* end export */

#ifdef	COMMENT

/* n= number-divisor-digits, quotient-digits are double */
template<integral_unsigned T2,integral_unsigned T1>
local bool vdivx(int n,T1 *q,T1 *r,T1 *u,T1 *v) noex {
    	cint		n2 = (n * 2) ;
    	cint		t2bits = nbits<T2>
    	cint		ndiv = nsigdig(n,v) ;
	bool		fz = true ;	/* divide-by-zero */
	DPRINTF("ent\n") ;
	if (ndiv) {
	    T2		num = vjoin<T2>(u) ;
	    T2		den = vjoin<T2>(v) ;
	    T2		tden = 0 ;
	    T2		estden = v[n-1] ;
	    T1		uu[n2+2] ;
	    cint	nu = nsigdig(n2,u) ;
	    fz = false ;
	    vcopy(n2,uu,u) ;
	    uu[n1+0] = 0 ;
	    uu[n2+1] = 0 ;
	    vclear(n2,q) ;
	    vclear(n,r) ;
	    for (int i = (nu - 1 - 1) ; i >= 0 ; --i) {
		T2	estnum ;
		T2	estrem ;
		T2	estpro{} ;
	        T2	estend = vjoin<Y2>(uu + i + 1) ;
		T2	dquo ;
		T2	drem ;
	        estden = v[n-1] ;
		estnum = vjoin<T2>(uu + i) ;
		forever {
		    dquo = estend / estden ;
		    drem = estend % estden ;
	            estpro = dquo * den ;
	            if (estpro <= estnum) break ;
	            estend -= 1 ;
		} /* end while */
		estrem = (estnum - estpro) ;
		q[i + 0] = T1(dquo >> 0) ;
		uu[i + 3] = 0 ;
		uu[i + 2] = 0 ;
		uu[i + 1] = T1(estrem >> (t2bits/2)) ; /* always zero */
		uu[i + 0] = T1(estrem >> 0) ;
	    } /* end for */
	    r[1] = uu[1] ;
	    r[0] = uu[0] ;
	} /* end if (zero-divisor detect) */
	DPRINTF("ent\n") ;
    	return fz ;
} /* end subroutine (vdivx) */

#endif /* COMMENT */

